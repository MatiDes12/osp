# ─── Supabase ───
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# ─── Redis ───
REDIS_URL=redis://localhost:6379

# ─── R2 / S3 Storage ───
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=osp-storage
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

# ─── API Gateway ───
GATEWAY_PORT=3000
GATEWAY_CORS_ORIGINS=http://localhost:3001

# ─── Go Services (gRPC ports) ───
INGEST_GRPC_PORT=50051
VIDEO_GRPC_PORT=50052
EVENT_GRPC_PORT=50053
EXTENSION_GRPC_PORT=50054

# ─── go2rtc ───
GO2RTC_API_URL=http://localhost:1984
GO2RTC_RTSP_PORT=8554
GO2RTC_WEBRTC_PORT=8555

# ─── Recordings ───
RECORDINGS_DIR=./recordings

# ─── Encryption ───
OSP_ENCRYPTION_KEY=generate-a-32-byte-key-here

# ─── Push Notifications ───
APNS_KEY_ID=your-key-id
APNS_TEAM_ID=your-team-id
FCM_SERVER_KEY=your-fcm-key

# ─── Email ───
SENDGRID_API_KEY=your-sendgrid-key
EMAIL_FROM=alerts@yourdomain.com
