# ─── Supabase ───
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# ─── Redis ───
REDIS_URL=redis://localhost:6379

# ─── R2 / S3 Storage ───
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=osp-storage
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

# ─── API Gateway ───
GATEWAY_PORT=3000
GATEWAY_CORS_ORIGINS=http://localhost:3001
# Rate limiter behavior when Redis is unavailable:
# true  => allow requests (fail-open, default)
# false => return 503 (fail-closed)
RATE_LIMIT_FAIL_OPEN=true

# Used by services that need to call the gateway (e.g. camera-ingest motion detection)
API_URL=http://localhost:3000
API_TOKEN=your-api-token

# ─── Go Services (gRPC ports) ───
INGEST_GRPC_PORT=50051
VIDEO_GRPC_PORT=50052
EVENT_GRPC_PORT=50053
EXTENSION_GRPC_PORT=50054

# ─── go2rtc ───
GO2RTC_API_URL=http://localhost:1984
GO2RTC_RTSP_PORT=8554
GO2RTC_WEBRTC_PORT=8555

# ─── TURN (remote WebRTC) ───
# Needed when viewers are not on the same LAN as the go2rtc/gateway.
# Configure one of:
# - Self-hosted coturn (recommended for full control)
# - Cloudflare TURN (free tier in many cases)
# - Twilio TURN (paid)
#
# IMPORTANT: Values must be the same for gateway and go2rtc if you override defaults.
TURN_SERVER_URL=turn:localhost:3478
TURN_SERVER_USERNAME=osp
TURN_SERVER_CREDENTIAL=osp

# ─── Recordings ───
RECORDINGS_DIR=./recordings

# ─── Encryption ───
OSP_ENCRYPTION_KEY=generate-a-32-byte-key-here

# ─── Push Notifications ───
APNS_KEY_ID=your-key-id
APNS_TEAM_ID=your-team-id
FCM_SERVER_KEY=your-fcm-key

# ─── Email ───
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=alerts@yourdomain.com

# ─── Error Monitoring (optional) ───
SENTRY_DSN=
