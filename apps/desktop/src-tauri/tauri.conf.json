{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "OSP",
  "version": "0.1.15",
  "identifier": "com.osp.desktop",
  "build": {
    "beforeDevCommand": "",
    "devUrl": "https://osp-web-eight.vercel.app/login",
    "beforeBuildCommand": "",
    "frontendDist": "https://osp-web-eight.vercel.app"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "OSP — Open Surveillance Platform",
        "url": "/login",
        "width": 1440,
        "height": 900,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "shadow": true
      }
    ],
    "security": {
      "csp": null,
      "dangerousDisableAssetCspModification": true,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**", "$HOME/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "shortDescription": "Open Surveillance Platform desktop client",
    "longDescription": "Monitor and manage your security cameras from the desktop with system tray integration, OS notifications, and auto-start support.",
    "externalBin": ["binaries/go2rtc", "binaries/camera-ingest"],
    "windows": {
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com"
    }
  }
}
