# ─── OSP Production Environment Variables ───────────────────────────────────
# Copy this file and fill in actual values before deploying.
# NEVER commit the real .env.production file to version control.

# ─── Supabase ────────────────────────────────────────────────────────────────
# Project URL from Supabase dashboard → Settings → API
SUPABASE_URL=https://CHANGE_ME.supabase.co

# Anonymous key (safe for client-side, used by web app)
SUPABASE_ANON_KEY=CHANGE_ME

# Service role key (server-side only, bypasses RLS)
SUPABASE_SERVICE_KEY=CHANGE_ME

# Direct database connection (used by migrations and Go services)
DATABASE_URL=postgresql://postgres.CHANGE_ME:CHANGE_ME@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# ─── Redis ───────────────────────────────────────────────────────────────────
# Managed Redis URL (e.g., Upstash, Redis Cloud, or self-hosted)
REDIS_URL=redis://default:CHANGE_ME@CHANGE_ME:6379

# ─── Cloudflare R2 (Object Storage for Recordings) ──────────────────────────
R2_ENDPOINT=https://CHANGE_ME.r2.cloudflarestorage.com
R2_ACCESS_KEY=CHANGE_ME
R2_SECRET_KEY=CHANGE_ME
R2_BUCKET=osp-recordings

# ─── go2rtc (Camera Streaming Proxy) ────────────────────────────────────────
# Internal URL where go2rtc API is reachable by other services
GO2RTC_URL=http://go2rtc:1984

# ─── Inter-Service URLs ─────────────────────────────────────────────────────
# Used by the gateway to reach Go microservices
CAMERA_INGEST_URL=http://camera-ingest:8080
VIDEO_PIPELINE_URL=http://video-pipeline:8081
EVENT_ENGINE_URL=http://event-engine:8082

# ─── Gateway ────────────────────────────────────────────────────────────────
NODE_ENV=production
GATEWAY_PORT=3000

# JWT secret for signing auth tokens (generate with: openssl rand -hex 32)
JWT_SECRET=CHANGE_ME

# ─── Web App (Next.js) ──────────────────────────────────────────────────────
# Public URL of the API gateway (used by the browser)
NEXT_PUBLIC_API_URL=https://api.CHANGE_ME.com
NEXT_PUBLIC_GO2RTC_URL=https://stream.CHANGE_ME.com
NEXT_PUBLIC_WS_URL=wss://api.CHANGE_ME.com/ws

# ─── WebRTC / TURN Server ───────────────────────────────────────────────────
# Required for WebRTC to work across NATs in production
# Options: Cloudflare Calls, Twilio TURN, coturn self-hosted
TURN_SERVER_URL=turn:CHANGE_ME:3478
TURN_USERNAME=CHANGE_ME
TURN_CREDENTIAL=CHANGE_ME

# ─── Email Notifications (Event Engine) ─────────────────────────────────────
SMTP_HOST=smtp.CHANGE_ME.com
SMTP_PORT=587
SMTP_USER=CHANGE_ME
SMTP_PASSWORD=CHANGE_ME
SMTP_FROM=noreply@CHANGE_ME.com

# ─── Push Notifications ─────────────────────────────────────────────────────
# Firebase Cloud Messaging for mobile push notifications
FCM_SERVER_KEY=CHANGE_ME

# ─── Monitoring (Optional) ──────────────────────────────────────────────────
# Sentry DSN for error tracking
SENTRY_DSN=https://CHANGE_ME@sentry.io/CHANGE_ME

# ─── Docker Image Registry ──────────────────────────────────────────────────
IMAGE_PREFIX=ghcr.io/matides12/osp
VERSION=latest
