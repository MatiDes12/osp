# ─────────────────────────────────────────────────────────────────────────────
# OSP Agent — Environment Variables
# Copy to .env.agent (or use this file as a template) and fill in your values.
# Run from infra/docker: docker compose --env-file .env.agent -f docker-compose.agent.yml up -d
# ─────────────────────────────────────────────────────────────────────────────

# Your OSP cloud gateway URL
CLOUD_GATEWAY_URL=https://osp-gateway.fly.dev

# Your tenant ID (find this in OSP dashboard → Settings → General)
TENANT_ID=your-tenant-id-here

# Your API token (find this in OSP dashboard → Settings → API Keys)
CLOUD_API_TOKEN=your-api-token-here

# ngrok auth token (free at https://dashboard.ngrok.com/get-started/your-authtoken)
# Required for the tunnel that enables remote live streaming and cloud snapshots.
# Without a real token, osp-ngrok exits with ERR_NGROK_4018 and the dashboard gets 502 on /snapshot.
NGROK_AUTHTOKEN=your-ngrok-authtoken-here

# Timezone (e.g. America/New_York, Europe/London, Asia/Dubai)
TZ=UTC

# Optional: override the public go2rtc URL if you have a static domain or named tunnel.
# Leave blank — the agent auto-discovers it from the bundled ngrok service.
# GO2RTC_PUBLIC_URL=
