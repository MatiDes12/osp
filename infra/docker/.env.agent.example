# ─────────────────────────────────────────────────────────────────────────────
# OSP Agent — Environment Variables
# Copy this file to .env.agent and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# Your OSP cloud gateway URL
GATEWAY_URL=https://osp-gateway.fly.dev

# Your tenant ID (find this in OSP dashboard → Settings → General)
TENANT_ID=your-tenant-id-here

# Your API token (find this in OSP dashboard → Settings → API Keys)
API_TOKEN=your-api-token-here

# Timezone (e.g. America/New_York, Europe/London, Asia/Dubai)
TZ=UTC

# Optional: override the public go2rtc URL if you have a static domain or named tunnel.
# Leave blank — the agent auto-discovers it from the bundled cloudflared service.
# GO2RTC_PUBLIC_URL=
